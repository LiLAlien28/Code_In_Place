from karel.stanfordkarel import *

"""
File: main.py
--------------------
When you finish writing this file, Karel should have repaired 
each of the columns in the temple
"""

def main():
    while front_is_clear():
        build_column()
        move_to_next_column()
    build_column()

def build_column():
    turn_left()
    while front_is_clear():
        put_beeper_if_needed()
        move()
    put_beeper_if_needed()
    turn_around()
    while front_is_clear():
        move()
    turn_left()

def move_to_next_column():
    for i in range(4):
        if front_is_clear():
            move()

def put_beeper_if_needed():
        put_beeper()

def turn_around():
    turn_left()
    turn_left()
  

if __name__ == '__main__':
    main()
